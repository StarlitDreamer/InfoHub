{
  "rss": {
    "url": "",
    "urls": [
      "https://example.com/a.xml",
      "https://example.com/b.xml"
    ]
  },
  "search": {
    "max_items": 10,
    "storage": {
      "dir": "data/searches"
    },
    "sources": [
      {
        "name": "stack-overflow",
        "kind": "stackexchange",
        "location": "stackoverflow",
        "enabled": true,
        "priority": 4,
        "timeout_seconds": 10,
        "max_items": 8
      },
      {
        "name": "reddit-programming",
        "kind": "reddit",
        "location": "programming",
        "enabled": true,
        "priority": 3,
        "timeout_seconds": 10,
        "max_items": 8
      },
      {
        "name": "google-rss-search",
        "kind": "rss_search",
        "location": "https://blog.google/rss/",
        "enabled": true,
        "priority": 2,
        "timeout_seconds": 10,
        "max_items": 6
      }
    ]
  },
  "ai": {
    "endpoint": "https://api.openai.com/v1/chat/completions",
    "api_key": "replace-with-your-api-key",
    "model": "gpt-4.1-mini"
  },
  "webhook": {
    "url": "https://example.com/webhook",
    "send_empty_report": false
  },
  "email": {
    "smtp_host": "smtp.example.com",
    "smtp_port": 587,
    "username": "mailer@example.com",
    "password": "replace-with-your-password",
    "from": "mailer@example.com",
    "to": [
      "team@example.com"
    ],
    "subject": "InfoHub 每日摘要"
  },
  "preference": {
    "tags": [
      "AI",
      "Agent"
    ],
    "sources": [
      "stack-overflow"
    ],
    "keywords": [
      "agent",
      "workflow"
    ],
    "weights": {
      "tag": 1.2,
      "source": 1.0,
      "keyword": 0.6
    }
  },
  "storage": {
    "dir": "data/reports"
  },
  "dedup": {
    "store_path": "data/dedup/seen.json"
  },
  "http": {
    "addr": ":8080"
  },
  "auth": {
    "token": ""
  },
  "redis": {
    "addr": "",
    "password": "",
    "db": 0,
    "dedup_key": "infohub:dedup:seen"
  },
  "mysql": {
    "dsn": "infohub:infohub@tcp(mysql:3306)/infohub?charset=utf8mb4&parseTime=true&loc=Local",
    "table": "reports",
    "search_table": "search_records",
    "preference_table": "user_preferences"
  },
  "scheduler": {
    "interval_seconds": 3600,
    "cron": "0 9,18 * * 1-5"
  }
}

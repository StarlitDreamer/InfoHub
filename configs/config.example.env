# 单个 RSS 数据源地址；留空时使用 Demo 数据。
INFOHUB_RSS_URL=https://example.com/rss.xml

# 多个 RSS 数据源地址，逗号分隔；设置后优先于 INFOHUB_RSS_URL。
INFOHUB_RSS_URLS=https://example.com/a.xml,https://example.com/b.xml

# OpenAI 兼容 Chat Completions 接口；任一项留空时使用 mock AI。
INFOHUB_AI_ENDPOINT=https://api.openai.com/v1/chat/completions
INFOHUB_AI_API_KEY=replace-with-your-api-key
INFOHUB_AI_MODEL=gpt-4.1-mini

# SMTP 邮件推送配置；留空时不发送邮件。
INFOHUB_SMTP_HOST=smtp.example.com
INFOHUB_SMTP_PORT=587
INFOHUB_SMTP_USERNAME=mailer@example.com
INFOHUB_SMTP_PASSWORD=replace-with-your-password
INFOHUB_EMAIL_FROM=mailer@example.com
INFOHUB_EMAIL_TO=team@example.com
INFOHUB_EMAIL_SUBJECT=InfoHub 每日报告

# 个性化偏好配置；用于给感兴趣的标签、来源和关键词加权。
INFOHUB_PREFERENCE_TAGS=AI,Agent
INFOHUB_PREFERENCE_SOURCES=openai-news
INFOHUB_PREFERENCE_KEYWORDS=agent,workflow
INFOHUB_PREFERENCE_TAG_WEIGHT=1.2
INFOHUB_PREFERENCE_SOURCE_WEIGHT=1.0
INFOHUB_PREFERENCE_KEYWORD_WEIGHT=0.6

# Webhook 推送地址；留空时只输出到终端。
INFOHUB_WEBHOOK_URL=https://example.com/webhook

# 无新增信息时是否仍推送 Webhook。
INFOHUB_SEND_EMPTY_REPORT=false

# 本地日报与条目快照保存目录。
INFOHUB_STORAGE_DIR=data/reports

# 跨运行去重状态文件路径。
INFOHUB_DEDUP_STORE_PATH=data/dedup/seen.json

# Gin HTTP 服务监听地址。
INFOHUB_HTTP_ADDR=:8080

# Gin API 鉴权 token；留空时不启用鉴权。
INFOHUB_AUTH_TOKEN=replace-with-secret

# Redis 去重配置；Addr 留空时使用文件版去重。
INFOHUB_REDIS_ADDR=localhost:6379
INFOHUB_REDIS_PASSWORD=
INFOHUB_REDIS_DB=0
INFOHUB_REDIS_DEDUP_KEY=infohub:dedup:seen

# MySQL 日报存储配置；DSN 留空时使用文件存储。
INFOHUB_MYSQL_DSN=infohub:infohub@tcp(localhost:3306)/infohub?charset=utf8mb4&parseTime=true&loc=Local
INFOHUB_MYSQL_TABLE=reports
INFOHUB_MYSQL_PREFERENCE_TABLE=user_preferences

# 定时任务间隔秒数，默认 3600。
INFOHUB_SCHEDULE_INTERVAL_SECONDS=3600

# Cron 表达式；设置后优先于固定间隔调度。
INFOHUB_SCHEDULE_CRON="0 9,18 * * 1-5"
